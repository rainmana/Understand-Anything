# LiteLLM-Proxy / OpenAI-compatible endpoint configuration
# Copy to .env and fill in your values.

# Base URL of your LiteLLM-Proxy instance (or any OpenAI-compatible API)
LITELLM_BASE_URL=http://localhost:4000

# API key (leave empty if your proxy doesn't require auth)
LITELLM_API_KEY=

# Model to use (must be configured in your LiteLLM proxy config)
LITELLM_MODEL=gpt-4o

# Max response tokens
LITELLM_MAX_TOKENS=4096
